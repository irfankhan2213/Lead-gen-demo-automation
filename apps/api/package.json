{
  "name": "@acquisition-engine/api",
  "version": "1.0.0",
  "private": true,
  "description": "Acquisition Engine — Express + TypeScript backend API",
  "scripts": {
    "dev": "tsc && mkdir -p dist/services/demo && cp -r src/services/demo/templates dist/services/demo/ && node dist/index.js",
    "build": "tsc --project tsconfig.json && mkdir -p dist/services/demo && cp -r src/services/demo/templates dist/services/demo/",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "psql $DATABASE_URL -f src/db/schema.sql",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@acquisition-engine/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.26.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/server": "^1.2.0",
    "@supabase/supabase-js": "^2.110.0",
    "bullmq": "^5.7.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonrepair": "^3.15.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "playwright": "^1.44.0",
    "resend": "^3.2.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  }
}
