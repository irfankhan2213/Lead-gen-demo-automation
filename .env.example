# ==============================
# Anthropic (Claude AI)
# ==============================
ANTHROPIC_API_KEY=

# ==============================
# Database (Supabase PostgreSQL)
# ==============================
DATABASE_URL=postgresql://postgres:password@localhost:5432/acquisition_engine

# ==============================
# Redis (Upstash or local)
# ==============================
REDIS_URL=redis://localhost:6379

# ==============================
# Vercel Deploy API (demo hosting)
# ==============================
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# ==============================
# Email (Resend.com)
# ==============================
RESEND_API_KEY=
FROM_EMAIL=you@yourdomain.com
FROM_NAME=Your Name

# ==============================
# Scraping (optional paid upgrade)
# ==============================
SERPAPI_KEY=
APIFY_TOKEN=

# ==============================
# Auth (Clerk.dev) — for dashboard
# ==============================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ==============================
# App Config
# ==============================
PORT=3001
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3001

# ==============================
# Rate Limits
# ==============================
SCRAPE_RATE_LIMIT_WINDOW_MS=60000
SCRAPE_RATE_LIMIT_MAX=10
